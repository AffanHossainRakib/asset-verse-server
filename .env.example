# Server Configuration
PORT=BACKEND_PORT                 # Port number for the backend server (e.g., 5000)
CLIENT_URL=Frontend_URL           # URL of the frontend application (e.g., http://localhost:5173)

# MongoDB Database Configuration
MONGODB_URI=YOUR_MONGODB_CONNECTION_STRING      # Primary MongoDB connection string
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1            # Optional: Custom DNS servers (used only if SRV DNS fails with ECONNREFUSED)
MONGODB_URI_FALLBACK=YOUR_MONGODB_FALLBACK_CONNECTION_STRING  # Optional: Fallback connection string (leave empty to disable fallback retry)

# Stripe Payment Integration
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY        # Stripe secret key for payment processing

# Firebase Admin SDK Configuration
FB_SERVICE_KEY=YOUR_FIREBASE_ADMIN_SDK_CREDENTIALS_BASE64_ENCODED  # Base64-encoded Firebase Admin SDK credentials JSON