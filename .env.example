PORT=BACKEND_PORT
CLIENT_URL=Frontend_URL

MONGODB_URI=YOUR_MONGODB_CONNECTION_STRING
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1 # Optional: only used if SRV DNS fails with ECONNREFUSED.
MONGODB_URI_FALLBACK=YOUR_MONGODB_FALLBACK_CONNECTION_STRING # Leave empty to disable fallback retry.

STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY

# Firebase Admin SDK credentials
FB_SERVICE_KEY=YOUR_FIREBASE_ADMIN_SDK_CREDENTIALS_BASE64_ENCODED